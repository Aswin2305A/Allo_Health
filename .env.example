# ─── Database ─────────────────────────────────────────────────────────────────
# Get this from Supabase, Neon, or Railway (connection pooling URL if available)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ─── Cron Security ────────────────────────────────────────────────────────────
# Set this to a random secret; Vercel Cron will send it in the Authorization header
CRON_SECRET="your-secret-here"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
